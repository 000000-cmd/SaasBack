# ===========================================
# BASE DE DATOS MYSQL
# ===========================================
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=saas_db

# ===========================================
# TIMEZONE
# ===========================================
TZ=America/Bogota

# ===========================================
# KAFKA
# ===========================================
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
# Dev local: solo levantamos kafka-1.
# Prod: borrar/comentar este bloque -> defaults 3 voters / RF=3 / ISR=2.
KAFKA_QUORUM_VOTERS=1@kafka-1:9093
KAFKA_INTERNAL_RF=1
KAFKA_INTERNAL_MIN_ISR=1
KAFKA_TOPIC_RF=1
KAFKA_TOPIC_MIN_ISR=1

# Heap por nodo ES.
#   Dev (1 nodo single-node): 1g recomendado.
#   Prod (3 nodos cluster): 1g por nodo (3GB total) o subir a 2g si el volumen lo justifica.
ES_JAVA_OPTS=-Xms1g -Xmx1g

KIBANA_ENCRYPTION_KEY=TpYtXFbKjzGCHkFGQcydvozoktclSkgZ

# Elasticsearch
ELASTIC_PASSWORD=ChangeM3

# ===========================================
# NOTAS:
# - NO usar MYSQL_USER/MYSQL_PASSWORD
# - NO usar SPRING_PROFILES_ACTIVE aquí
# - Cada servicio define su profile en docker-compose.yml
# ===========================================
